# Kraken API credentials (required)
KRAKEN_KEY=your-kraken-api-key
KRAKEN_PASSCODE=your-kraken-secret

# LLM Provider: 'ollama', 'openrouter', or 'opencode' (default: ollama)
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
LLM_MODEL=qwen3.5:cloud
OLLAMA_TIMEOUT_MS=180000            # Request timeout in ms (default: 180s, cloud models need more time)

# OpenRouter API (used when LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
# LLM_MODEL=x-ai/grok-3-mini-beta

# OpenCode Zen API (used when LLM_PROVIDER=opencode)
# Get your key at https://opencode.ai/auth
# OPENCODE_API_KEY=oc-your-api-key-here
# LLM_MODEL=opencode-go/glm-5.1         # opencode-go models
# LLM_MODEL=opencode/big-pickle         # opencode zen enabled models

# Optional settings
# PORT=8000                           # Web dashboard port
# AI_ENABLED=true                     # Enable/disable AI trading
# ANALYSIS_INTERVAL_MINUTES=30        # How often AI runs analysis
# COUNTRY_CODE=NL                     # ISO 3166-1 alpha-2 country code to filter available trading pairs
# EDIT_PASSWORD=your-secret-password  # Password to edit strategy (required for web edits)
